# ==========================================
# Environment Configuration (Template)
# Copy this file to '.env' and fill in the actual values
# ==========================================

# Execution environment (development, staging, production)
ENVIRONMENT=development

# API routing prefix
API_V1_PREFIX=/api/v1

# ==========================================
# 🔐 Security (Auth & JWT)
# ==========================================
# In production, generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_dev_key_do_not_use_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# 🗄️ Database
# ==========================================
# Format: postgresql+asyncpg://user:password@host:port/db_name
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fintech_db